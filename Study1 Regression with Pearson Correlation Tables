import pandas as pd
import statsmodels.api as sm
import numpy as np

# Load the CSV file
df = pd.read_csv("/Users/mathewfeehan/Library/Mobile Documents/com~apple~CloudDocs/PhD Research/IRA/Study 2 and 3 Final Data/3millionTweets_CorrectedPartisanWords.CLEAN.csv")

# Define MFT independent variables
mft_ivs = [
    "Loyaltyclassification_result",
    "Sanctityclassification_result",
    "Careclassification_result",
    "Fairnessclassification_result",
    "Authorityclassification_result",
]

# Process 'affect' column
emotion_df = pd.DataFrame([eval(v) for v in df["affect"]])
emotion_df = emotion_df.fillna(0)
emotion_clean_df = emotion_df.drop(columns=["anticip", "anticipation"])

# Determine relevant indices
rel_index = emotion_clean_df[emotion_clean_df.sum(axis=1) > 0].index
rel_index = df.loc[rel_index].dropna(subset=["retweet_count"]).index

# Define dependent variables
y_ols = np.log2(df.loc[rel_index]["retweet_count"].copy() + 1)
y_glm = df.loc[rel_index]["like_count"].copy()

# Regression function with printed correlation tables
def run_regression(X, y_ols, y_glm, description):
    print(f"\n>>> Running regression: {description}")
    print(f"  → X rows: {X.shape[0]}, y rows: {y_ols.shape[0]}")
    
    # Correlation matrix and summary stats
    corr = X.corr().round(3)
    summary = pd.DataFrame({
        "Mean": X.mean().round(3),
        "SD": X.std().round(3),
        "N": X.count()
    })
    print(f"\n[Correlation Matrix – {description}]:\n{corr.to_string()}")
    print(f"\n[Summary Stats – {description}]:\n{summary.to_string()}")

    ols_model = sm.OLS(y_ols, X).fit()
    glm_model = sm.GLM(y_glm, X, family=sm.families.NegativeBinomial(alpha=2)).fit(cov_type="HC2")

    print(f"\nOLS Regression ({description}):")
    print(ols_model.summary())
    print(f"\nGLM Regression ({description}):")
    print(glm_model.summary())

# 1. Follower Count Only
X_followers = sm.add_constant(np.log2(df.loc[rel_index]["follower_count"] + 1))
run_regression(X_followers, y_ols, y_glm, "Follower Count Only")

# 2. Emotion + Follower Count
X_emotion = emotion_clean_df.loc[rel_index].drop(columns=["negative", "positive"])
X_emotion = sm.add_constant(pd.concat([X_emotion, np.log2(df.loc[rel_index]["follower_count"] + 1).rename("follower_count")], axis=1))
run_regression(X_emotion, y_ols, y_glm, "Emotion + Follower Count")

# 2.5 MFT Only + Follower Count
X_mft = pd.DataFrame(index=rel_index)
for mft_v in mft_ivs:
    X_mft[mft_v] = df.loc[rel_index][mft_v].apply(
        lambda s: float(s.partition("(")[-1].partition(")")[0]) if isinstance(s, str) else 0
    )
X_mft["follower_count"] = np.log2(df.loc[rel_index]["follower_count"] + 1)
X_mft = sm.add_constant(X_mft)
run_regression(X_mft, y_ols, y_glm, "MFT + Follower Count")

# 3. Emotion + MFT + Follower Count
X_emotion_mft = X_emotion.copy()
for mft_v in mft_ivs:
    X_emotion_mft[mft_v] = df.loc[rel_index][mft_v].apply(
        lambda s: float(s.partition("(")[-1].partition(")")[0]) if isinstance(s, str) else 0
    )
run_regression(X_emotion_mft, y_ols, y_glm, "Emotion + MFT + Follower Count")

# 4. Emotion + MFT + Partisan Word Count + Follower Count
X_emotion_mft_partisan = X_emotion_mft.copy()
X_emotion_mft_partisan["partisan_word_count"] = df.loc[rel_index]["partisan_word_count"]
run_regression(X_emotion_mft_partisan, y_ols, y_glm, "Emotion + MFT + Partisan Word Count + Follower Count")

# 5. Individual Partisan Words + Follower Count
print("\n[INFO] Running full partisan word regressions...")

df["partisan_words"] = df["partisan_words"].fillna("").str.lower().str.split(", ")
unique_words = set(word for words in df["partisan_words"] for word in words if word)

X_partisan = pd.DataFrame({word: df["partisan_words"].apply(lambda x: int(word in x)) for word in unique_words}, index=df.index)
X_partisan["follower_count"] = np.log2(df["follower_count"] + 1)
X_partisan = sm.add_constant(X_partisan.loc[rel_index])

ols_model = sm.OLS(y_ols, X_partisan).fit()
glm_model = sm.GLM(y_glm, X_partisan, family=sm.families.NegativeBinomial(alpha=2)).fit(cov_type="HC2")

print("\nOLS Regression (Partisan Words + Follower Count):")
print(ols_model.summary())

print("\nGLM Regression (Partisan Words + Follower Count):")
print(glm_model.summary())
